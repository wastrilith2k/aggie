# Firebase Functions Environment Variables
# These are set via: firebase functions:secrets:set SECRET_NAME

# Master encryption key for token encryption (32 bytes hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=your_master_key_here

# Google OAuth credentials
# Get from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft OAuth credentials
# Get from Azure Portal -> App registrations
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Trello API credentials
# Get from https://trello.com/power-ups/admin
TRELLO_API_KEY=your_trello_api_key
TRELLO_API_SECRET=your_trello_api_secret

# Application URL (for OAuth redirects)
APP_URL=https://your-app-domain.web.app
